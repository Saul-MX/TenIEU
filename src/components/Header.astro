---
import LogoImg from '../assets/logo-tenIEU.png'
import ArrowIcon from "../assets/icons/Chevron.astro";
import BuscarIcon from "../assets/icons/Buscar.astro";
import MoonIcon from "../assets/icons/Moon.astro";
import ShoppingIcon from "../assets/icons/Shopping.astro";
import UserIcon from '../assets/icons/User.astro';
import SoccerIcon from "../assets/icons/Soccer.astro";
import BasketballIcon from "../assets/icons/Basketball.astro";
import RunningIcon from "../assets/icons/Running.astro";
import SkateboardIcon from "../assets/icons/Skateboarding.astro";
import ShoeIcon from "../assets/icons/Shoe.astro";
import ArrowRightIcon from "../assets/icons/Arrow.astro";
---

<header class="header">
  <nav class="navbar">

    <!-- LOGO -->
    <div class="content-logo">
      <a class="contentainer-logo" href="/TenIEU">
        <img class="img-logo" src={LogoImg.src} alt="Logo TenIEU">
        <h1>TenIEU</h1>
      </a>
    </div>

    <!-- NAV DESKTOP -->
    <ul class="header-list">
      <li class="header-link">
        <a href="/TenIEU">Home</a>
      </li>
      <li class="header-link dropdown">
        <a href="#">
          Categories
          <ArrowIcon class="w-6"/>
        </a>
        <ul class="header-dropdown">
          <li class="dropdown-link"><a href="#"><SoccerIcon class="w-10"/>Soccer</a></li>
          <li class="dropdown-link"><a href="#"><BasketballIcon class="w-10"/>Basketball</a></li>
          <li class="dropdown-link"><a href="#"><RunningIcon class="w-10"/>Running</a></li>
          <li class="dropdown-link"><a href="#"><ShoeIcon class="w-10"/>Lifestyle</a></li>
          <li class="dropdown-link"><a href="#"><SkateboardIcon class="w-10"/>Street</a></li>
          <div class="line"></div>
          <li class="dropdown-link active"><a href="#">See more<ArrowRightIcon class="w-10"/></a></li>
        </ul>
      </li>
      <li class="header-link">
        <a href="/TenIEU/productos">Products</a>
      </li>
    </ul>

    <!-- ICONOS DESKTOP -->
    <section class="header-conf">
      <div class="header-conf-input"><BuscarIcon class="w-12 h-12"/></div>
      <div class="header-conf-darkmode"><MoonIcon class="w-12 h-12"/></div>
      <div class="header-conf-shopping">
        <a href="/TenIEU/carrito"><ShoppingIcon class="w-12 h-12"/></a>
      </div>
      <div class="header-conf-profile">
        <UserIcon class="w-12 h-12"/>
      </div>
    </section>

    <!-- HAMBURGER BUTTON -->
    <button class="hamburger" id="hamburger" aria-label="Abrir menú">
      <span></span>
      <span></span>
      <span></span>
    </button>

  </nav>
</header>

<!-- MOBILE MENU OVERLAY -->
<div class="mobile-overlay" id="mobileOverlay">

  <!-- CLOSE -->
  <button class="mobile-close" id="mobileClose" aria-label="Cerrar menú">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

  <!-- SEARCH -->
  <div class="mobile-search">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input type="text" placeholder="Buscar...">
  </div>

  <!-- LINKS -->
  <ul class="mobile-list">

    <li class="mobile-item">
      <a href="/TenIEU" class="mobile-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Home
      </a>
    </li>

    <!-- Categorias accordion -->
    <li class="mobile-item">
      <button class="mobile-link mobile-accordion-btn" id="catBtn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Categorias
      </button>
      <ul class="mobile-sub" id="catSub">
        <li><a href="#"><SoccerIcon class="w-8"/>Soccer</a></li>
        <li><a href="#"><BasketballIcon class="w-8"/>Basketball</a></li>
        <li><a href="#"><RunningIcon class="w-8"/>Running</a></li>
        <li><a href="#"><ShoeIcon class="w-8"/>Lifestyle</a></li>
        <li><a href="#"><SkateboardIcon class="w-8"/>Street</a></li>
      </ul>
    </li>

    <li class="mobile-item">
      <a href="/TenIEU/productos" class="mobile-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        Productos
      </a>
    </li>

    <li class="mobile-item">
      <button class="mobile-link" id="darkBtn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        Modo
      </button>
    </li>

    <li class="mobile-item">
      <a href="/TenIEU/carrito" class="mobile-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        Carrito
      </a>
    </li>

    <li class="mobile-item">
      <a href="#" class="mobile-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        Perfil
      </a>
    </li>

  </ul>
</div>

<script>
  const hamburger = document.getElementById('hamburger')!;
  const overlay   = document.getElementById('mobileOverlay')!;
  const closeBtn  = document.getElementById('mobileClose')!;
  const catBtn    = document.getElementById('catBtn')!;
  const catSub    = document.getElementById('catSub')!;

  hamburger.addEventListener('click', () => {
    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  });

  const closeMenu = () => {
    overlay.classList.remove('open');
    document.body.style.overflow = '';
  };

  closeBtn.addEventListener('click', closeMenu);
  overlay.addEventListener('click', (e) => { if (e.target === overlay) closeMenu(); });

  catBtn.addEventListener('click', () => {
    catSub.classList.toggle('open');
    catBtn.classList.toggle('expanded');
  });
</script>

<style>
  /* ─── HEADER BASE ─── */
  .header {
    width: 100%;
    height: 9rem;
    position: sticky;
    top: 0;
    background-color: var(--color-white);
    border-radius: 0 0 2rem 2rem;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    z-index: 1000;
  }

  .navbar {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 2.4rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* ─── LOGO ─── */
  .content-logo { display: flex; align-items: center; }
  .contentainer-logo { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; color: inherit; }
  .img-logo { width: 5rem; }
  .content-logo h1 { font-size: 2.5rem; font-weight: 800; }

  /* ─── NAV DESKTOP ─── */
  .header-list {
    display: flex;
    gap: 2rem;
    font-size: 2rem;
    font-weight: 600;
  }

  .header-link a {
    transition: color 0.2s;
    text-decoration: none;
    color: inherit;
  }
  .header-link a:hover { color: var(--primary-color); }

  .dropdown {
    display: flex;
    flex-direction: column;
    position: relative;
  }
  .dropdown a { display: flex; gap: 1rem; align-items: center; }
  .dropdown::before {
    content: '';
    position: absolute;
    top: 1rem;
    left: 0;
    width: 100%;
    height: 8rem;
  }

  .header-dropdown {
    display: none;
    flex-direction: column;
    position: absolute;
    top: 6.5rem;
    left: 10%;
    gap: 1rem;
    padding: .5rem;
    background-color: var(--color-white);
    border-radius: 1rem;
    z-index: 10;
    box-shadow: 0 8px 24px rgba(0,0,0,.1);
    min-width: 18rem;
  }
  .dropdown:hover .header-dropdown { display: flex; }

  .dropdown-link a {
    color: var(--color-title);
    padding: 1rem 2rem;
    border-radius: 1rem;
    transition: all 0.1s;
  }
  .dropdown-link:hover a { background-color: var(--orange-pastel); }
  .dropdown-link.active a { background-color: var(--color-white); color: var(--secondary-color); border-radius: 5px; }
  .dropdown-link.active:hover a { color: var(--color-white); background-color: var(--secondary-color); }

  .line { width: 100%; height: 1px; background-color: var(--color-title); }

  /* ─── ICONOS DESKTOP ─── */
  .header-conf { display: flex; justify-content: space-around; gap: 2rem; }
  .header-conf div { transition: color 0.1s; cursor: pointer; }
  .header-conf div:hover { color: var(--primary-color); }
  .header-conf a { color: inherit; }

  /* ─── HAMBURGER ─── */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 0.55rem;
    width: 3.6rem;
    height: 3.6rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.4rem;
    border-radius: 0.6rem;
    transition: background .2s;
  }
  .hamburger:hover { background: rgba(0,0,0,.06); }
  .hamburger span {
    display: block;
    width: 100%;
    height: 2.5px;
    background: currentColor;
    border-radius: 2px;
    transition: transform .3s, opacity .3s;
  }

  /* ─── MOBILE OVERLAY ─── */
  .mobile-overlay {
    position: fixed;
    inset: 0;
    background: var(--color-white, #fff);
    z-index: 2000;
    padding: 2.4rem 2.4rem 4rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    transform: translateX(100%);
    transition: transform .35s cubic-bezier(.4,0,.2,1);
    overflow-y: auto;
  }
  .mobile-overlay.open { transform: translateX(0); }

  /* close btn */
  .mobile-close {
    align-self: flex-end;
    width: 4rem; height: 4rem;
    background: none; border: none; cursor: pointer;
    color: var(--color-title, #111);
    display: flex; align-items: center; justify-content: center;
    border-radius: 50%;
    transition: background .2s;
  }
  .mobile-close:hover { background: rgba(0,0,0,.06); }
  .mobile-close svg { width: 2.4rem; height: 2.4rem; }

  /* search */
  .mobile-search {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    background: #f0f0f0;
    border-radius: 1.2rem;
    padding: 1.2rem 1.6rem;
  }
  .mobile-search svg { width: 2rem; height: 2rem; color: #888; flex-shrink: 0; }
  .mobile-search input {
    flex: 1;
    border: none;
    background: none;
    font-size: 1.6rem;
    font-family: inherit;
    outline: none;
    color: var(--color-title, #111);
  }
  .mobile-search input::placeholder { color: #aaa; }

  /* list */
  .mobile-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; }

  .mobile-item { border-bottom: 1px solid #f0f0f0; }

  .mobile-link {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    width: 100%;
    padding: 1.8rem 0.4rem;
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-title, #111);
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    text-align: left;
    transition: color .2s;
  }
  .mobile-link:hover { color: var(--primary-color, #FF6B00); }
  .mobile-link svg { width: 2.4rem; height: 2.4rem; flex-shrink: 0; color: #555; }

  /* accordion sub */
  .mobile-sub {
    list-style: none;
    padding: 0 0 1rem 4rem;
    margin: 0;
    display: none;
    flex-direction: column;
    gap: 0.4rem;
  }
  .mobile-sub.open { display: flex; }

  .mobile-sub li a {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    padding: 1rem 0.4rem;
    font-size: 1.6rem;
    font-weight: 600;
    color: #555;
    text-decoration: none;
    transition: color .2s;
  }
  .mobile-sub li a:hover { color: var(--primary-color, #FF6B00); }

  .mobile-accordion-btn svg { transition: transform .3s; }
  .mobile-accordion-btn.expanded svg { transform: rotate(-90deg); }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 768px) {
    .header-list  { display: none; }
    .header-conf  { display: none; }
    .hamburger    { display: flex; }
  }
</style>