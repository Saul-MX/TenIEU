---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<Layout>
    <Header />
        <!-- BRAND STRIP — infinite marquee (pure CSS) -->
        <section class="brand-strip">
        <div class="brand-track-wrap">
            <div class="brand-track">

            <!-- ── SET 1 ── -->
            <div class="brand-logo">
                <svg viewBox="0 0 100 40" fill="currentColor"><path d="M9.17 34.2L48.3 5.98c4.43-3.1 9.95-4.08 13.42-2.4 3.79 1.83 4.36 6.4 1.28 10.85L9.17 34.2z"/></svg>
                <span>NIKE</span>
            </div>
            <div class="brand-logo">
                <svg viewBox="0 0 60 40" fill="currentColor"><path d="M30 4L6 36h10l14-24 14 24h10L30 4z"/><rect x="6" y="32" width="48" height="4"/></svg>
                <span>adidas</span>
            </div>
            <div class="brand-logo reebok">
                <svg viewBox="0 0 80 30" fill="currentColor"><text x="0" y="24" font-size="26" font-weight="700" font-family="Georgia,serif" letter-spacing="-1">Reebok</text></svg>
            </div>
            <div class="brand-logo">
                <svg viewBox="0 0 50 40" fill="currentColor"><text x="4" y="22" font-size="28" font-weight="900" font-family="Arial,sans-serif">NB</text></svg>
                <span class="small">new balance</span>
            </div>
            <div class="brand-logo">
                <svg viewBox="0 0 70 40" fill="currentColor"><text x="0" y="30" font-size="30" font-weight="900" font-family="Arial Black,sans-serif" letter-spacing="1">PUMA</text></svg>
            </div>
            <div class="brand-sep">✦</div>

            <!-- ── SET 2 ── -->
            <div class="brand-logo">
                <svg viewBox="0 0 100 40" fill="currentColor"><path d="M9.17 34.2L48.3 5.98c4.43-3.1 9.95-4.08 13.42-2.4 3.79 1.83 4.36 6.4 1.28 10.85L9.17 34.2z"/></svg>
                <span>NIKE</span>
            </div>
            <div class="brand-logo">
                <svg viewBox="0 0 60 40" fill="currentColor"><path d="M30 4L6 36h10l14-24 14 24h10L30 4z"/><rect x="6" y="32" width="48" height="4"/></svg>
                <span>adidas</span>
            </div>
            <div class="brand-logo reebok">
                <svg viewBox="0 0 80 30" fill="currentColor"><text x="0" y="24" font-size="26" font-weight="700" font-family="Georgia,serif" letter-spacing="-1">Reebok</text></svg>
            </div>
            <div class="brand-logo">
                <svg viewBox="0 0 50 40" fill="currentColor"><text x="4" y="22" font-size="28" font-weight="900" font-family="Arial,sans-serif">NB</text></svg>
                <span class="small">new balance</span>
            </div>
            <div class="brand-logo">
                <svg viewBox="0 0 70 40" fill="currentColor"><text x="0" y="30" font-size="30" font-weight="900" font-family="Arial Black,sans-serif" letter-spacing="1">PUMA</text></svg>
            </div>
            <div class="brand-sep">✦</div>

            <!-- ── SET 3 ── -->
            <div class="brand-logo">
                <svg viewBox="0 0 100 40" fill="currentColor"><path d="M9.17 34.2L48.3 5.98c4.43-3.1 9.95-4.08 13.42-2.4 3.79 1.83 4.36 6.4 1.28 10.85L9.17 34.2z"/></svg>
                <span>NIKE</span>
            </div>
            <div class="brand-logo">
                <svg viewBox="0 0 60 40" fill="currentColor"><path d="M30 4L6 36h10l14-24 14 24h10L30 4z"/><rect x="6" y="32" width="48" height="4"/></svg>
                <span>adidas</span>
            </div>
            <div class="brand-logo reebok">
                <svg viewBox="0 0 80 30" fill="currentColor"><text x="0" y="24" font-size="26" font-weight="700" font-family="Georgia,serif" letter-spacing="-1">Reebok</text></svg>
            </div>
            <div class="brand-logo">
                <svg viewBox="0 0 50 40" fill="currentColor"><text x="4" y="22" font-size="28" font-weight="900" font-family="Arial,sans-serif">NB</text></svg>
                <span class="small">new balance</span>
            </div>
            <div class="brand-logo">
                <svg viewBox="0 0 70 40" fill="currentColor"><text x="0" y="30" font-size="30" font-weight="900" font-family="Arial Black,sans-serif" letter-spacing="1">PUMA</text></svg>
            </div>
            <div class="brand-sep">✦</div>

            </div>
        </div>
        </section>

        <!-- PRODUCT DETAIL -->
        <section class="product-detail">

        <!-- LEFT: Gallery -->
        <div class="gallery">
            <div class="thumbs">
            <button class="thumb active">
                <img src="https://images.unsplash.com/photo-1600185365483-26d7a4cc7519?w=200&q=80" alt="Vista 1">
            </button>
            <button class="thumb">
                <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=200&q=80" alt="Vista 2">
            </button>
            <button class="thumb">
                <img src="https://images.unsplash.com/photo-1595950653106-6c9ebd614d3a?w=200&q=80" alt="Vista 3">
            </button>
            <button class="thumb">
                <img src="https://images.unsplash.com/photo-1491553895911-0055eca6402d?w=200&q=80" alt="Vista 4">
            </button>
            <button class="thumb">
                <img src="https://images.unsplash.com/photo-1525966222134-fcfa99b8ae77?w=200&q=80" alt="Vista 5">
            </button>
            </div>

            <div class="main-img-wrap">
            <img id="mainImg" src="https://images.unsplash.com/photo-1600185365483-26d7a4cc7519?w=900&q=85" alt="Giannis Immortality EP">
            <div class="img-nav">
                <button class="nav-btn" id="prevBtn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
                </button>
                <button class="nav-btn" id="nextBtn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
                </button>
            </div>
            </div>
        </div>

        <!-- RIGHT: Info -->
        <div class="product-info">

            <div class="badge-row">
            <span class="badge-featured">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:1.4rem;height:1.4rem"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                Altamente valorado
            </span>
            </div>

            <h1 class="product-name">Giannis Immortality EP</h1>

            <div class="meta-row">
            <span class="category">Tenis de basketball</span>
            <span class="free-ship">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:1.4rem;height:1.4rem"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                Envio gratis
            </span>
            </div>

            <div class="price-row">
            <span class="price-current">$4,499</span>
            <span class="price-old">$4,499</span>
            </div>

            <div class="section-label">Elige el color</div>
            <div class="color-variants">
            <button class="variant active"><img src="https://images.unsplash.com/photo-1600185365483-26d7a4cc7519?w=120&q=80" alt="Color 1"></button>
            <button class="variant"><img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=120&q=80" alt="Color 2"></button>
            <button class="variant"><img src="https://images.unsplash.com/photo-1595950653106-6c9ebd614d3a?w=120&q=80" alt="Color 3"></button>
            <button class="variant"><img src="https://images.unsplash.com/photo-1608231387042-66d1773070a5?w=120&q=80" alt="Color 4"></button>
            <button class="variant"><img src="https://images.unsplash.com/photo-1539185441755-769473a23570?w=120&q=80" alt="Color 5"></button>
            <button class="variant"><img src="https://images.unsplash.com/photo-1560769629-975ec94e6a86?w=120&q=80" alt="Color 6"></button>
            <button class="variant"><img src="https://images.unsplash.com/photo-1491553895911-0055eca6402d?w=120&q=80" alt="Color 7"></button>
            <button class="variant"><img src="https://images.unsplash.com/photo-1525966222134-fcfa99b8ae77?w=120&q=80" alt="Color 8"></button>
            </div>

            <div class="section-label">Selecciona tu talla</div>
            <div class="size-grid">
            <button class="size-btn">CM 22</button>
            <button class="size-btn">CM 22.5</button>
            <button class="size-btn">CM 23</button>
            <button class="size-btn">CM 23.5</button>
            <button class="size-btn">CM 24</button>
            <button class="size-btn">CM 24.5</button>
            <button class="size-btn">CM 25</button>
            <button class="size-btn">CM 25.5</button>
            <button class="size-btn">CM 26</button>
            <button class="size-btn">CM 26.5</button>
            <button class="size-btn">CM 27</button>
            <button class="size-btn">CM 27.5</button>
            <button class="size-btn">CM 28</button>
            <button class="size-btn">CM 28.5</button>
            <button class="size-btn">CM 29</button>
            <button class="size-btn">CM 29.5</button>
            </div>

            <div class="action-row">
            <button class="btn-add">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                Añadir al Carrito
            </button>
            <button class="btn-fav">
                Favoritos
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            </button>
            </div>

        </div>
        </section>
    <Footer />
</Layout>

<style>
  /* ─── BRAND STRIP — infinite marquee ─── */
  .brand-strip {
    border-bottom: 1px solid var(--border, #E2E2E2);
    padding: 2.8rem 0;
  }

  .brand-track-wrap {
    position: relative;
    overflow: hidden;
  }
  .brand-track-wrap::before,
  .brand-track-wrap::after {
    content: '';
    position: absolute;
    top: 0; bottom: 0;
    width: 12rem;
    z-index: 2;
    pointer-events: none;
  }
  .brand-track-wrap::before {
    left: 0;
    background: linear-gradient(to right, var(--color-white, #fff), transparent);
  }
  .brand-track-wrap::after {
    right: 0;
    background: linear-gradient(to left, var(--color-white, #fff), transparent);
  }

  .brand-track {
    display: flex;
    align-items: center;
    gap: 6rem;
    width: max-content;
    animation: marquee 22s linear infinite;
  }

  .brand-strip:hover .brand-track { animation-play-state: paused; }

  @keyframes marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-33.3333%); }
  }

  .brand-logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    color: #555;
    opacity: 0.65;
    transition: opacity .2s;
    cursor: pointer;
    flex-shrink: 0;
    user-select: none;
  }
  .brand-logo:hover { opacity: 1; }
  .brand-logo svg { height: 3.6rem; width: auto; }
  .brand-logo span { font-size: 1.3rem; font-weight: 700; letter-spacing: .05em; }
  .brand-logo span.small { font-size: 1rem; letter-spacing: .08em; }
  .brand-logo.reebok svg { height: 2.4rem; }
  .brand-sep { font-size: 1.6rem; color: #ccc; flex-shrink: 0; user-select: none; }

  /* ─── PRODUCT DETAIL ─── */
  .product-detail {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2.4rem 6rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  /* ─── GALLERY ─── */
  .gallery {
    display: flex;
    gap: 1.6rem;
    align-items: flex-start;
  }

  .thumbs {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    flex-shrink: 0;
  }

  .thumb {
    width: 7.2rem;
    height: 7.2rem;
    border-radius: 1.2rem;
    border: 2px solid transparent;
    overflow: hidden;
    background: #fff;
    cursor: pointer;
    padding: 0;
    transition: border-color .2s, box-shadow .2s;
    flex-shrink: 0;
  }
  .thumb img { width: 100%; height: 100%; object-fit: cover; }
  .thumb.active {
    border-color: #FF6B00;
    box-shadow: 0 0 0 3px rgba(255,107,0,.15);
  }
  .thumb:hover:not(.active) { border-color: #E2E2E2; }

  .main-img-wrap {
    flex: 1;
    position: relative;
    background: #fff;
    border-radius: 2rem;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    box-shadow: 0 2px 16px rgba(0,0,0,.07);
  }
  .main-img-wrap img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: opacity .3s;
  }

  .img-nav {
    position: absolute;
    bottom: 2rem; right: 2rem;
    display: flex;
    gap: 0.8rem;
  }

  .nav-btn {
    width: 4.2rem; height: 4.2rem;
    border-radius: 50%;
    background: rgba(255,220,180,0.85);
    border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    backdrop-filter: blur(4px);
    transition: background .2s, transform .15s;
    box-shadow: 0 2px 10px rgba(0,0,0,.12);
  }
  .nav-btn:hover { background: #FF6B00; color: #fff; transform: scale(1.08); }
  .nav-btn svg { width: 1.8rem; height: 1.8rem; }

  /* ─── PRODUCT INFO ─── */
  .product-info {
    display: flex;
    flex-direction: column;
    padding-top: 1rem;
  }

  .badge-row { margin-bottom: 1.6rem; }
  .badge-featured {
    display: inline-flex; align-items: center; gap: 0.6rem;
    padding: 0.7rem 1.8rem;
    background: #FF6B00; color: #fff;
    font-size: 1.4rem; font-weight: 600;
    border-radius: 99px;
  }

  .product-name {
    font-size: clamp(2.4rem, 3.5vw, 3.6rem);
    font-weight: 800; line-height: 1.1;
    margin-bottom: 1.4rem;
  }

  .meta-row {
    display: flex; align-items: center; gap: 2rem;
    margin-bottom: 1.6rem;
  }
  .category { font-size: 1.6rem; color: #777; font-weight: 500; }
  .free-ship {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 1.5rem; font-weight: 600; color: #FF6B00;
  }

  .price-row {
    display: flex; align-items: center; gap: 1.2rem;
    margin-bottom: 2.4rem;
  }
  .price-current { font-size: 2.6rem; font-weight: 800; }
  .price-old { font-size: 2rem; font-weight: 500; color: #777; text-decoration: line-through; }

  .section-label {
    font-size: 1.5rem; font-weight: 600;
    margin-bottom: 1.2rem; margin-top: 0.4rem;
  }

  .color-variants {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
    margin-bottom: 2.4rem;
  }
  .variant {
    aspect-ratio: 1;
    border-radius: 1rem;
    border: 2px solid transparent;
    overflow: hidden; background: #fff;
    cursor: pointer; padding: 0;
    transition: border-color .2s, box-shadow .2s;
  }
  .variant img { width: 100%; height: 100%; object-fit: cover; }
  .variant.active {
    border-color: #2a2a2a;
    box-shadow: 0 0 0 3px rgba(0,0,0,.08);
  }
  .variant:hover:not(.active) { border-color: #E2E2E2; }

  .size-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 3rem;
  }
  .size-btn {
    padding: 1.1rem 0.8rem;
    border-radius: 1rem; border: none;
    background: #2a2a2a; color: #fff;
    font-size: 1.3rem; font-weight: 600;
    cursor: pointer;
    transition: background .2s, transform .15s;
    white-space: nowrap;
  }
  .size-btn:hover { background: #444; transform: translateY(-1px); }
  .size-btn.active { background: #FF6B00; }

  .action-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
  }
  .btn-add, .btn-fav {
    display: flex; align-items: center; justify-content: center; gap: 0.8rem;
    padding: 1.4rem 2rem;
    border-radius: 1.2rem; border: none;
    font-size: 1.5rem; font-weight: 700;
    cursor: pointer; background: #FF6B00; color: #fff;
    transition: background .2s, transform .15s;
  }
  .btn-add:hover, .btn-fav:hover { background: #e05e00; transform: translateY(-2px); }
  .btn-add svg, .btn-fav svg { width: 1.8rem; height: 1.8rem; flex-shrink: 0; }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 1024px) {
    .product-detail { gap: 3rem; }
    .color-variants { grid-template-columns: repeat(4, 1fr); }
  }

  @media (max-width: 768px) {
    .product-detail {
      grid-template-columns: 1fr;
      padding: 2.4rem 1.6rem 4rem;
      gap: 3rem;
    }
    .gallery { flex-direction: column-reverse; }
    .thumbs { flex-direction: row; flex-wrap: wrap; }
    .thumb { width: 6rem; height: 6rem; }
    .main-img-wrap { aspect-ratio: 4 / 3; }
    .color-variants { grid-template-columns: repeat(5, 1fr); }
    .size-grid { grid-template-columns: repeat(4, 1fr); }
    .brand-logo svg { height: 2.8rem; }
  }

  @media (max-width: 480px) {
    .product-name { font-size: 2.4rem; }
    .size-grid { grid-template-columns: repeat(3, 1fr); }
    .action-row { grid-template-columns: 1fr; }
    .color-variants { grid-template-columns: repeat(4, 1fr); }
  }
</style>
