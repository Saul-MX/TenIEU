---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Header />

    <!-- CONFIRMACIÓN FINAL -->
    <section class="checkout-page">

        <!-- LEFT -->
        <div class="checkout-left">

            <!-- STEPPER — los 3 activos -->
            <div class="stepper">
            <div class="step active"><div class="step-dot"></div></div>
            <div class="step-line active"></div>
            <div class="step active"><div class="step-dot"></div></div>
            <div class="step-line active"></div>
            <div class="step active"><div class="step-dot"></div></div>
            </div>

            <h1 class="checkout-title">Confirma tu pedido</h1>
            <div class="form-divider"></div>

            <!-- ITEM -->
            <div class="cart-item">
            <div class="item-img">
                <img src="https://images.unsplash.com/photo-1600185365483-26d7a4cc7519?w=300&q=80" alt="Giannis Immortality EP">
            </div>

            <div class="item-body">
                <div class="item-top">
                <div class="item-info">
                    <p class="item-name">Tenis Giannis Immortality EP</p>
                    <p class="item-desc">Tenis de basketball color Blanco/Azul</p>
                    <p class="item-desc">Talla: 27 cm</p>
                </div>
                <p class="item-price">$4,499</p>
                </div>

                <div class="item-actions">
                <span class="item-qty">Cantidad: 1</span>
                <a href="#" class="action-link">Eliminar</a>
                <a href="#" class="action-link">Compartir</a>
                <a href="#" class="btn-pagar">Pagar</a>
                </div>
            </div>
            </div>

        </div>

        <!-- RIGHT: resumen -->
        <aside class="checkout-summary">
            <p class="summary-subtotal">
            Subtotal (1 producto): <strong>$4,499</strong>
            </p>
            <p class="summary-shipping">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            Envio gratis
            </p>
        </aside>

    </section>

  <Footer />
</Layout>

<style>
  /* ─── LAYOUT ─── */
  .checkout-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2.4rem 8rem;
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 5rem;
    align-items: start;
  }

  /* ─── STEPPER ─── */
  .stepper {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 3.6rem;
  }

  .step { display: flex; align-items: center; }

  .step-dot {
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 50%;
    background: #D0D0D0;
    flex-shrink: 0;
    transition: background .3s;
  }
  .step.active .step-dot { background: #FF6B00; }

  .step-line {
    width: 8rem;
    height: 2.5px;
    background: #4a5568;
    flex-shrink: 0;
  }
  .step-line.active { background: #FF6B00; }

  /* ─── TITLE ─── */
  .checkout-title {
    font-size: clamp(2.8rem, 3vw, 3.6rem);
    font-weight: 800;
    margin-bottom: 1.2rem;
  }

  .form-divider {
    height: 1.5px;
    background: #ccc;
    margin-bottom: 2.8rem;
  }

  /* ─── ITEM ─── */
  .cart-item {
    display: flex;
    gap: 2.4rem;
    align-items: flex-start;
  }

  .item-img {
    width: 14rem;
    height: 14rem;
    flex-shrink: 0;
    background: #fff;
    border-radius: 1.2rem;
    overflow: hidden;
    box-shadow: 0 2px 10px rgba(0,0,0,.07);
  }
  .item-img img { width: 100%; height: 100%; object-fit: cover; }

  .item-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
    padding-top: 0.4rem;
  }

  .item-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
  }

  .item-name {
    font-size: 1.9rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
  }
  .item-desc {
    font-size: 1.4rem;
    color: #777;
    line-height: 1.7;
  }

  .item-price {
    font-size: 2rem;
    font-weight: 700;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ─── ACTIONS ─── */
  .item-actions {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .item-qty {
    font-size: 1.4rem;
    font-weight: 500;
    color: #333;
  }

  .action-link {
    font-size: 1.4rem;
    font-weight: 500;
    color: #444;
    text-decoration: none;
    transition: color .2s;
  }
  .action-link:hover { color: #FF6B00; }

  .btn-pagar {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.1rem 3.2rem;
    background: #FF6B00;
    color: #fff;
    font-size: 1.5rem;
    font-weight: 700;
    border-radius: 1rem;
    text-decoration: none;
    transition: background .2s, transform .15s;
    margin-left: auto;
  }
  .btn-pagar:hover { background: #e05e00; transform: translateY(-2px); }

  /* ─── SUMMARY ─── */
  .checkout-summary {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: sticky;
    top: 10rem;
    padding-top: 1rem;
  }

  .summary-subtotal { font-size: 1.5rem; color: #333; }
  .summary-subtotal strong { font-weight: 800; }

  .summary-shipping {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.5rem;
    font-weight: 600;
    color: #FF6B00;
  }
  .summary-shipping svg { width: 1.6rem; height: 1.6rem; flex-shrink: 0; }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 768px) {
    .checkout-page {
      grid-template-columns: 1fr;
      gap: 3rem;
      padding: 2.4rem 1.6rem 6rem;
    }
    .checkout-summary { position: static; order: -1; }
    .step-line { width: 5rem; }
    .btn-pagar { margin-left: 0; width: 100%; }
    .item-actions { flex-direction: column; align-items: flex-start; }
  }

  @media (max-width: 480px) {
    .cart-item { flex-direction: column; }
    .item-img { width: 100%; height: 18rem; }
    .item-top { flex-direction: column; gap: 0.8rem; }
  }
</style>