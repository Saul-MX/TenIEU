---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Header />

    <!-- CONFIRMA TU PEDIDO -->
    <section class="cart-page">

        <!-- LEFT: productos -->
        <div class="cart-left">
            <h1 class="cart-title">Confirma tu pedido</h1>

            <div class="cart-header">
            <span></span>
            <span class="col-precio">Precio</span>
            </div>
            <div class="cart-divider"></div>

            <!-- ITEM -->
            <div class="cart-item">
            <div class="item-img">
                <img src="https://images.unsplash.com/photo-1600185365483-26d7a4cc7519?w=300&q=80" alt="Giannis Immortality EP">
            </div>

            <div class="item-body">
                <div class="item-top">
                <div class="item-info">
                    <p class="item-name">Tenis Giannis Immortality EP</p>
                    <p class="item-desc">Tenis de basketball color Blanco/Azul</p>
                    <p class="item-desc">Talla: 27 cm</p>
                </div>
                <p class="item-price">$4,499</p>
                </div>

                <div class="item-actions">
                <div class="qty-control">
                    <a href="#" class="qty-btn qty-del" aria-label="Eliminar uno">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                    </a>
                    <span class="qty-num">1</span>
                    <a href="#" class="qty-btn qty-add" aria-label="Agregar uno">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    </a>
                </div>

                <a href="#" class="action-link">Eliminar</a>
                <a href="#" class="action-link">Compartir</a>
                </div>
            </div>
            </div>

        </div>

        <!-- RIGHT: resumen -->
        <aside class="cart-summary">
            <p class="summary-subtotal">
            Subtotal (1 producto): <strong>$4,499</strong>
            </p>
            <p class="summary-shipping">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            Envio gratis
            </p>
            <a href="/TenIEU/pago" class="btn-checkout">Proceder al pago</a>
        </aside>

    </section>

    <style>
    /* ─── LAYOUT ─── */
    .cart-page {
        max-width: 1200px;
        margin: 0 auto;
        padding: 4rem 2.4rem 8rem;
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 4rem;
        align-items: start;
    }

    /* ─── LEFT ─── */
    .cart-title {
        font-size: clamp(2.4rem, 3vw, 3.2rem);
        font-weight: 800;
        margin-bottom: 2rem;
    }

    .cart-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-bottom: 1rem;
    }
    .col-precio {
        font-size: 1.6rem;
        font-weight: 700;
    }

    .cart-divider {
        height: 1.5px;
        background: #ccc;
        margin-bottom: 2.4rem;
    }

    /* ─── ITEM ─── */
    .cart-item {
        display: flex;
        gap: 2.4rem;
        align-items: flex-start;
    }

    .item-img {
        width: 14rem;
        height: 14rem;
        flex-shrink: 0;
        background: #fff;
        border-radius: 1.2rem;
        overflow: hidden;
        box-shadow: 0 2px 10px rgba(0,0,0,.07);
    }
    .item-img img {
        width: 100%; height: 100%;
        object-fit: cover;
    }

    .item-body {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 1.4rem;
        padding-top: 0.4rem;
    }

    .item-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 2rem;
    }

    .item-name {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 0.6rem;
    }
    .item-desc {
        font-size: 1.4rem;
        color: #777;
        line-height: 1.6;
    }

    .item-price {
        font-size: 2rem;
        font-weight: 700;
        white-space: nowrap;
        flex-shrink: 0;
    }

    /* ─── ACCIONES ─── */
    .item-actions {
        display: flex;
        align-items: center;
        gap: 1.6rem;
        flex-wrap: wrap;
    }

    /* cantidad */
    .qty-control {
        display: flex;
        align-items: center;
        gap: 0;
        background: #FF6B00;
        border-radius: 99px;
        padding: 0.4rem 0.6rem;
    }

    .qty-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.8rem;
        height: 2.8rem;
        border-radius: 50%;
        color: #fff;
        text-decoration: none;
        transition: background .15s;
        flex-shrink: 0;
    }
    .qty-btn:hover { background: rgba(255,255,255,.2); }
    .qty-btn svg { width: 1.4rem; height: 1.4rem; }

    .qty-num {
        font-size: 1.5rem;
        font-weight: 700;
        color: #fff;
        min-width: 2.2rem;
        text-align: center;
    }

    .action-link {
        font-size: 1.4rem;
        font-weight: 500;
        color: #444;
        text-decoration: none;
        transition: color .2s;
    }
    .action-link:hover { color: #FF6B00; }

    /* ─── SUMMARY ─── */
    .cart-summary {
        background: #fff;
        border-radius: 1.6rem;
        border: 1px solid #E2E2E2;
        padding: 2.4rem;
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
        position: sticky;
        top: 10rem;
    }

    .summary-subtotal {
        font-size: 1.5rem;
        color: #333;
    }
    .summary-subtotal strong {
        font-weight: 800;
    }

    .summary-shipping {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 1.5rem;
        font-weight: 600;
        color: #FF6B00;
    }
    .summary-shipping svg { width: 1.6rem; height: 1.6rem; flex-shrink: 0; }

    .btn-checkout {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.3rem 2rem;
        background: #FF6B00;
        color: #fff;
        font-size: 1.5rem;
        font-weight: 700;
        border-radius: 1rem;
        text-decoration: none;
        transition: background .2s, transform .15s;
        margin-top: 0.4rem;
    }
    .btn-checkout:hover { background: #e05e00; transform: translateY(-2px); }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 768px) {
        .cart-page {
        grid-template-columns: 1fr;
        gap: 3rem;
        padding: 2.4rem 1.6rem 6rem;
        }
        .cart-summary { position: static; }
        .item-img { width: 11rem; height: 11rem; }
        .item-name { font-size: 1.6rem; }
    }

    @media (max-width: 480px) {
        .cart-item { flex-direction: column; }
        .item-img { width: 100%; height: 18rem; }
        .item-top { flex-direction: column; gap: 0.8rem; }
    }
    </style>

  <Footer />
</Layout>