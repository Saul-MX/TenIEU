---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Header />

    <!-- DIRECCIÓN -->
    <section class="checkout-page">

        <!-- LEFT -->
        <div class="checkout-left">

            <!-- STEPPER -->
            <div class="stepper">
            <div class="step active">
                <div class="step-dot"></div>
            </div>
            <div class="step-line active"></div>
            <div class="step active">
                <div class="step-dot"></div>
            </div>
            <div class="step-line"></div>
            <div class="step">
                <div class="step-dot"></div>
            </div>
            </div>

            <!-- FORM -->
            <h1 class="checkout-title">Direccion</h1>
            <div class="form-divider"></div>

            <div class="checkout-form">

            <div class="field-row-top">
                <div class="field-group">
                <label class="field-label" for="calle">Calle</label>
                <input class="field-input" type="text" id="calle" autocomplete="street-address">
                </div>

                <div class="field-group">
                <label class="field-label" for="colonia">Colonia</label>
                <input class="field-input" type="text" id="colonia">
                </div>

                <a href="/TenIEU/pago-confirmacion" class="btn-continuar">Continuar</a>
            </div>

            <div class="field-row-bottom">
                <div class="field-group">
                <label class="field-label" for="cp">Codigo Postal</label>
                <input class="field-input small" type="text" id="cp" placeholder="XXXXX" maxlength="5">
                </div>

                <div class="field-group">
                <label class="field-label" for="ext">Num. Exterior</label>
                <input class="field-input small" type="text" id="ext" placeholder="XXXXX">
                </div>

                <div class="field-group">
                <label class="field-label" for="int">Num. Interior (opcional)</label>
                <input class="field-input small" type="text" id="int" placeholder="XXXXX">
                </div>
            </div>

            </div>
        </div>

        <!-- RIGHT: resumen -->
        <aside class="checkout-summary">
            <p class="summary-subtotal">
            Subtotal (1 producto): <strong>$4,499</strong>
            </p>
            <p class="summary-shipping">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            Envio gratis
            </p>
        </aside>

    </section>

    <style>
    /* ─── LAYOUT ─── */
    .checkout-page {
        max-width: 1200px;
        margin: 0 auto;
        padding: 4rem 2.4rem 8rem;
        display: grid;
        grid-template-columns: 1fr 280px;
        gap: 5rem;
        align-items: start;
    }

    /* ─── STEPPER ─── */
    .stepper {
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 3.6rem;
    }

    .step { display: flex; align-items: center; }

    .step-dot {
        width: 2.6rem;
        height: 2.6rem;
        border-radius: 50%;
        background: #D0D0D0;
        flex-shrink: 0;
        transition: background .3s;
    }
    .step.active .step-dot { background: #FF6B00; }

    .step-line {
        width: 8rem;
        height: 2.5px;
        background: #4a5568;
        flex-shrink: 0;
    }
    .step-line.active { background: #FF6B00; }

    /* ─── TITLE ─── */
    .checkout-title {
        font-size: clamp(2.8rem, 3vw, 3.6rem);
        font-weight: 800;
        margin-bottom: 1.2rem;
    }

    .form-divider {
        height: 1.5px;
        background: #ccc;
        margin-bottom: 3rem;
    }

    /* ─── FORM ─── */
    .checkout-form {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        max-width: 70rem;
    }

    /* top row: Calle + Colonia + botón */
    .field-row-top {
        display: flex;
        align-items: flex-end;
        gap: 2rem;
        flex-wrap: wrap;
    }

    .field-row-top .field-group { flex: 1; min-width: 14rem; }

    /* bottom row: CP + Ext + Int */
    .field-row-bottom {
        display: flex;
        align-items: flex-end;
        gap: 1.6rem;
        flex-wrap: wrap;
    }

    .field-group { display: flex; flex-direction: column; gap: 0.6rem; }

    .field-label {
        font-size: 1.35rem;
        font-weight: 500;
        color: #444;
        white-space: nowrap;
    }

    .field-input {
        padding: 1.1rem 1.4rem;
        border: 1.5px solid #D0D0D0;
        border-radius: 0.8rem;
        font-size: 1.4rem;
        font-family: inherit;
        background: #fff;
        color: #111;
        outline: none;
        transition: border-color .2s, box-shadow .2s;
        width: 100%;
    }
    .field-input:focus {
        border-color: #FF6B00;
        box-shadow: 0 0 0 3px rgba(255,107,0,.12);
    }
    .field-input::placeholder { color: #bbb; }

    .field-input.small { width: 11rem; }

    /* continuar */
    .btn-continuar {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.25rem 3.6rem;
        background: #FF6B00;
        color: #fff;
        font-size: 1.6rem;
        font-weight: 700;
        border-radius: 1rem;
        text-decoration: none;
        white-space: nowrap;
        flex-shrink: 0;
        transition: background .2s, transform .15s;
        align-self: flex-end;
    }
    .btn-continuar:hover { background: #e05e00; transform: translateY(-2px); }

    /* ─── SUMMARY ─── */
    .checkout-summary {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        position: sticky;
        top: 10rem;
        padding-top: 1rem;
    }

    .summary-subtotal { font-size: 1.5rem; color: #333; }
    .summary-subtotal strong { font-weight: 800; }

    .summary-shipping {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 1.5rem;
        font-weight: 600;
        color: #FF6B00;
    }
    .summary-shipping svg { width: 1.6rem; height: 1.6rem; flex-shrink: 0; }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 900px) {
        .field-row-top { flex-wrap: wrap; }
        .btn-continuar { width: 100%; }
    }

    @media (max-width: 768px) {
        .checkout-page {
        grid-template-columns: 1fr;
        gap: 3rem;
        padding: 2.4rem 1.6rem 6rem;
        }
        .checkout-summary { position: static; order: -1; }
        .step-line { width: 5rem; }
    }

    @media (max-width: 480px) {
        .field-row-bottom { flex-direction: column; }
        .field-input.small { width: 100%; }
    }
    </style>

  <Footer />
</Layout>